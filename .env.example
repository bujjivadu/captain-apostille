# Copy to .env and fill in values before deploying.
# Not used by the binaries directly – source this in your shell or systemd EnvironmentFile.

# ── captain-apostille ─────────────────────────────────────────────────────────

APOSTILLE_CONFIG=/etc/captain-apostille/apostille.conf
RUST_LOG=info

# ── captain-mast ──────────────────────────────────────────────────────────────

MAST_CONFIG=/etc/captain-mast/mast.conf

# ── Hugging Face (optional threat detection) ──────────────────────────────────

HF_API_KEY=hf_xxxxxxxxxxxxxxxxxxxx
